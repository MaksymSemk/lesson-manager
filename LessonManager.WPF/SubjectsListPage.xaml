<Page x:Class="LessonManager.WPF.SubjectsListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LessonManager.WPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SubjectsListPage">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Навчальні предмети" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2D3E50"/>

            <ListBox x:Name="SubjectsList" 
         ItemsSource="{Binding Subjects}" 
         DisplayMemberPath="BaseSubject.Title" 
         SelectionChanged="SubjectsList_SelectionChanged"
         FontSize="18" Height="300"/>
        </StackPanel>
    </Grid>
</Page>
