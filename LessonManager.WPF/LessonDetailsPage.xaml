<Page x:Class="LessonManager.WPF.LessonDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Деталі заняття">
    <Grid Margin="20">
        <StackPanel>
            <Button Content="← Назад до предмета" Click="Back_Click" HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,20"/>

            <TextBlock Text="Детальна інформація про заняття" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2D3E50"/>

            <Border BorderBrush="#D1D1D1" BorderThickness="1" Padding="20" Background="#F9F9F9">
                <StackPanel>
                    <TextBlock Text="{Binding Lesson.BaseLesson.Topic, StringFormat='Тема: {0}'}" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Lesson.BaseLesson.Type, StringFormat='Тип: {0}'}" FontSize="16" Margin="0,5"/>
                    <TextBlock Text="{Binding Lesson.BaseLesson.Date, StringFormat='Дата: {0:dd.MM.yyyy}'}" FontSize="16"/>
                    <TextBlock Text="{Binding Lesson.BaseLesson.StartTime, StringFormat='Початок: {0}'}" FontSize="16"/>

                    <Separator Margin="0,15"/>

                    <TextBlock Text="{Binding Lesson.Duration, StringFormat='Тривалість: {0:hh\\:mm}'}" 
                   FontSize="18" FontWeight="Bold" Foreground="Green"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>