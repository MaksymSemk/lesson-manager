<Page x:Class="LessonManager.WPF.LessonDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Деталі заняття">
    <Grid Margin="20">
        <StackPanel>
            <Button Content="← Назад до предмета" Click="Back_Click" HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,20"/>

            <TextBlock Text="Детальна інформація про заняття" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2D3E50"/>

            <Border BorderBrush="#D1D1D1" BorderThickness="1" Padding="20" CornerRadius="5" Background="#F9F9F9">
                <StackPanel>
                    <TextBlock x:Name="TxtTopic" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="TxtType" FontSize="16" Margin="0,5"/>
                    <TextBlock x:Name="TxtDate" FontSize="16" Margin="0,5"/>
                    <TextBlock x:Name="TxtTime" FontSize="16" Margin="0,5"/>

                    <Separator Margin="0,15"/>

                    <TextBlock x:Name="TxtDuration" FontSize="18" FontWeight="Bold" Foreground="Green"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>