<Page x:Class="LessonManager.WPF.SubjectDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Деталі предмета">
    <Grid Margin="20">
        <StackPanel>
            <Button Content="← Назад" Click="Back_Click" HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,20"/>

            <TextBlock x:Name="TxtTitle" FontSize="28" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock x:Name="TxtInfo" FontSize="16" Margin="0,0,0,20"/>

            <TextBlock Text="Список занять:" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ListBox x:Name="LessonsList" Height="200" SelectionChanged="LessonsList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <TextBlock Text="{Binding BaseLesson.Date, StringFormat=dd.MM}" FontWeight="Bold" Width="50"/>
                            <TextBlock Text="{Binding BaseLesson.Topic}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Page>