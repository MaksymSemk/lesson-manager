<Page x:Class="LessonManager.WPF.SubjectDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LessonManager.WPF"
      Title="Деталі предмета">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Orientation="Vertical">
            <!-- Back button -->
            <Button Content="← Назад" 
                    Click="Back_Click" 
                    HorizontalAlignment="Left" 
                    Padding="10,5" 
                    Margin="0,0,0,20"
                    Background="#95A5A6"
                    Foreground="White"/>

            <!-- Loading indicator -->
            <ProgressBar IsIndeterminate="True" 
                         Height="5"
                         Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Margin="0,0,0,10"/>

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="Red" 
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource EmptyStringToCollapsedConverter}}"
                       Margin="0,0,0,10"/>

            <!-- Subject info and edit fields -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Назва предмета:" FontSize="14" FontWeight="Bold"/>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="10" 
                         Margin="0,5,0,10"
                         FontSize="16"/>

                <TextBlock Text="Кредити ECTS:" FontSize="14" FontWeight="Bold"/>
                <TextBox Text="{Binding EctsCredits, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="10" 
                         Margin="0,5,0,10"
                         FontSize="16"/>

                <TextBlock Text="Сфера знань:" FontSize="14" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding Source={x:Static local:EnumHelper.KnowledgeAreas}}" 
                          SelectedItem="{Binding Area}"
                          Padding="10" 
                          Margin="0,5,0,20"
                          FontSize="16"/>

                <Button Content="Зберегти зміни" 
                        Command="{Binding SaveChangesCommand}"
                        Padding="10,8" 
                        Background="#3498DB" 
                        Foreground="White"
                        Margin="0,0,0,20"/>
            </StackPanel>

            <!-- Lessons section -->
            <TextBlock Text="Список занять:" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Пошук за темою:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Width="150" Text="{Binding LessonNameFilter, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                <TextBlock Text="Фільтр за датою:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <DatePicker SelectedDate="{Binding LessonDateFilter, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                <TextBlock Text="Сортування:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                <ComboBox Width="120" SelectedValue="{Binding LessonSortOption, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content">
                    <ComboBoxItem Content="Name"/>
                    <ComboBoxItem Content="Date"/>
                    <ComboBoxItem Content="Duration"/>
                </ComboBox>
                <Button Content="Очистити" Margin="10,0,0,0" Padding="5,2" Command="{Binding ClearLessonFiltersCommand}"/>
            </StackPanel>

            <!-- Lessons ListBox -->
            <ListBox x:Name="LessonsList"
                     ItemsSource="{Binding Lessons}" 
                     SelectedItem="{Binding SelectedLesson}"
                     Margin="0,0,0,10"
                     FontSize="16">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding BaseLesson.Topic}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding BaseLesson.Date, StringFormat='Дата: 0:dd.MM.yyyy'}" Foreground="Gray" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding BaseLesson.Type}" 
                                       Foreground="Gray" 
                                       VerticalAlignment="Center"
                                       Margin="10,0"/>
                            <TextBlock Grid.Column="2" 
                                       Text="{Binding Duration, StringFormat='Тривалість: 0:hh\\:mm'}" 
                                       Foreground="Gray" 
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Lesson buttons -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Перегляд" 
                        Click="ViewLessonButton_Click"
                        Padding="10,5" 
                        Background="#3498DB" 
                        Foreground="White"
                        IsEnabled="{Binding SelectedLesson, Converter={StaticResource NullToBooleanConverter}}"
                        Margin="0,0,10,0"/>
                <Button Content="Додати заняття" 
                        Command="{Binding AddLessonCommand}"
                        Padding="10,5" 
                        Background="#27AE60" 
                        Foreground="White"
                        Margin="0,0,10,0"/>
                <Button Content="Видалити заняття" 
                        Command="{Binding DeleteLessonCommand}"
                        Padding="10,5" 
                        Background="#E74C3C" 
                        Foreground="White"
                        Margin="0,0,10,0"/>
                <Button Content="Оновити" 
                        Command="{Binding LoadLessonsCommand}"
                        Padding="10,5" 
                        Background="#95A5A6" 
                        Foreground="White"
                        Margin="0,0,10,0"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>